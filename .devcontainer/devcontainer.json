{
  "name": "Vampire Survivors Clone (LibGDX)",
  "image": "mcr.microsoft.com/devcontainers/java:17",
  
  "features": {
    "ghcr.io/devcontainers/features/desktop-lite:1": {
      "password": "poodo"
    }
  },

  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y libx11-dev libxcursor-dev libgl1-mesa-glx libgl1-mesa-dri libglfw3 xvfb",

  "customizations": {
    "vscode": {
      "settings": {
        "java.format.settings.url": ".vscode/formatter.xml"
      },
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-gradle"
      ]
    }
  },

  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": {
      "label": "Desktop Virtual",
      "onAutoForward": "notify"
    }
  }
}